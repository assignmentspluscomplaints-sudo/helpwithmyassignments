generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Post {
  id         Int      @id @default(autoincrement())
  title      String   @db.VarChar(500)
  slug       String   @unique @db.VarChar(500)
  excerpt    String   @db.Text
  content    String   @db.LongText
  coverImage String?  @db.VarChar(1000)
  category   String   @default("General") @db.VarChar(100)
  author     String   @default("Admin") @db.VarChar(200)
  readTime   Int      @default(5)
  published  Boolean  @default(false)
  metaTitle  String?  @db.VarChar(500)
  metaDesc   String?  @db.Text
  focusKw    String?  @db.VarChar(200)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(200)
  password  String   @db.VarChar(200)
  createdAt DateTime @default(now())
}